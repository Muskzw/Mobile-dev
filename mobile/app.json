{
  "expo": {
    "name": "AI Quotation Maker",
    "slug": "quotation-maker-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B82F6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quotationmaker.app",
      "infoPlist": {
        "NSContactsUsageDescription": "We need access to your contacts to import them as clients"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B82F6"
      },
      "package": "com.quotationmaker.app",
      "permissions": [
        "READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Quotation Maker to access your contacts to import clients."
        }
      ],
      "@react-native-google-signin/google-signin"
    ]
  }
}